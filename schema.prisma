// =============================================================================
// Draft Zone League — Prisma schema
// =============================================================================
// Two layers live here:
//   1. CATALOGUE  — your fully editable football data (clubs, players, managers,
//                   ratings). This is what the admin system imports/exports and
//                   what the draft pool is built from. NOTHING is hardcoded in
//                   application code.
//   2. GAME STATE — a live two-player game: rooms, the 20 teams, the draft,
//                   the fixtures, the simulated matches and the league table.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 1. CATALOGUE  (admin-managed, data-driven football data)
// =============================================================================

// A real-world season label, e.g. "1998/99". Reused across many club-versions.
model Season {
  id        String   @id @default(cuid())
  label     String   @unique // "1998/99", "2007/08"
  startYear Int // 1998
  createdAt DateTime @default(now())

  clubs Club[]
}

// A HISTORICAL club-version. "Manchester United 1998/99" and
// "Manchester United 2007/08" are two separate Club rows.
// The line ratings here represent the club's overall strength for that season
// and are blended with the actual drafted players during simulation.
model Club {
  id       String @id @default(cuid())
  name     String // "Manchester United"
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id])

  country String
  league  String

  overallRating     Int // 0-100
  attackRating      Int
  midfieldRating    Int
  defenceRating     Int
  goalkeepingRating Int

  // The manager-version most associated with this club-version (optional link).
  managerRatingId String?         @unique
  managerRating   ManagerRating?  @relation("ClubDefaultManager", fields: [managerRatingId], references: [id])

  playerRatings  PlayerRating[]
  managerRatings ManagerRating[] @relation("ClubManagers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, seasonId]) // a club-version is unique per season
  @@index([league])
  @@index([country])
}

// A player's IDENTITY (stable across the historical versions of that player).
model Player {
  id          String @id @default(cuid())
  name        String
  nationality String

  primaryPosition    Position
  secondaryPositions Position[] // e.g. [LM, RW]

  specialTraits String[] // "Playmaker", "Poacher", "Wall", "Engine"...

  ratings PlayerRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// A specific HISTORICAL CARD: this player AS THEY WERE in a given club-version.
// This is the unit that gets drafted. "Beckham @ Man Utd 1998/99" is one row,
// "Beckham @ Real Madrid 2003/04" would be another.
model PlayerRating {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  clubId   String
  club     Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)

  ageDuringSeason Int

  overall      Int // 0-100
  pace         Int
  shooting     Int
  passing      Int
  creativity   Int
  defending    Int
  physical     Int
  goalkeeping  Int
  consistency  Int
  bigMatch     Int
  leadership   Int
  injuryResist Int
  potential    Int

  draftSelections DraftSelection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, clubId]) // one card per player per club-version
  @@index([clubId])
}

// A manager's IDENTITY.
model Manager {
  id   String @id @default(cuid())
  name String

  ratings ManagerRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// A manager AS THEY WERE in a given club-version. Draftable, like a player card.
model ManagerRating {
  id        String  @id @default(cuid())
  managerId String
  manager   Manager @relation(fields: [managerId], references: [id], onDelete: Cascade)
  clubId    String
  club      Club    @relation("ClubManagers", fields: [clubId], references: [id], onDelete: Cascade)

  overall          Int
  attackingStyle   Int // higher = more attack-minded
  defensiveStyle   Int // higher = more defensively solid
  possession       Int
  counterAttack    Int
  playerDevelopment Int
  discipline       Int
  adaptability     Int
  bigMatch         Int

  defaultForClub  Club?            @relation("ClubDefaultManager")
  draftSelections DraftSelection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([managerId, clubId])
  @@index([clubId])
}

enum Position {
  GK
  CB
  LB
  RB
  CDM
  CM
  CAM
  LM
  RM
  LW
  RW
  ST
  CF
}

// =============================================================================
// 2. GAME STATE  (a live two-player session)
// =============================================================================

model Game {
  id        String     @id @default(cuid())
  roomCode  String     @unique // short shareable code
  status    GameStatus @default(LOBBY)
  // Whose draft turn it is right now (references a GamePlayer.id), null outside drafting.
  activeTurnPlayerId String?
  currentRound       Int        @default(1) // 1..10 (one team per player per round)
  // RNG seed so the whole season is deterministic / reproducible on reconnect.
  seasonSeed         String?

  players  GamePlayer[]
  teams    Team[]
  fixtures Fixture[]
  matches  Match[]
  table    LeagueTableRow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GameStatus {
  LOBBY        // waiting for both players + ready
  TEAM_CREATION// naming teams for the current round
  DRAFTING     // turn-based drafting in progress
  SEASON_READY // all 20 teams built, fixtures generated
  SIMULATING   // season being played out
  COMPLETE     // final results available
}

model GamePlayer {
  id          String  @id @default(cuid())
  gameId      String
  game        Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  displayName String
  slot        Int // 1 or 2
  isReady     Boolean @default(false)
  // Socket id for the current connection (nullable while disconnected).
  socketId    String?
  connected   Boolean @default(false)

  teams Team[]

  createdAt DateTime @default(now())

  @@unique([gameId, slot])
}

model Team {
  id       String     @id @default(cuid())
  gameId   String
  game     Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  ownerId  String
  owner    GamePlayer @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name     String
  round    Int // which of the 10 rounds created this team

  selections DraftSelection[]
  homeFix    Fixture[]        @relation("HomeTeam")
  awayFix    Fixture[]        @relation("AwayTeam")
  tableRow   LeagueTableRow?

  createdAt DateTime @default(now())

  @@unique([gameId, name]) // team names unique within a game
}

model DraftSelection {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  slot SquadSlot // which slot in the XI (or MANAGER) this fills

  playerRatingId  String?
  playerRating    PlayerRating?  @relation(fields: [playerRatingId], references: [id])
  managerRatingId String?
  managerRating   ManagerRating? @relation(fields: [managerRatingId], references: [id])

  pickNumber Int // global pick order within the game (for replay/audit)
  createdAt  DateTime @default(now())

  @@unique([teamId, slot]) // each slot filled once per team
}

// 1 manager + 1 GK + 4 DEF + 3 MID + 3 FWD = 12 slots per team.
enum SquadSlot {
  MANAGER
  GK
  DEF1
  DEF2
  DEF3
  DEF4
  MID1
  MID2
  MID3
  FWD1
  FWD2
  FWD3
}

model Fixture {
  id         String @id @default(cuid())
  gameId     String
  game       Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  matchday   Int // 1..38
  homeTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeamId String
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)

  match Match?

  @@unique([gameId, homeTeamId, awayTeamId])
  @@index([gameId, matchday])
}

model Match {
  id        String  @id @default(cuid())
  gameId    String
  game      Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  fixtureId String  @unique
  fixture   Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  homeGoals Int
  awayGoals Int
  homeXg    Float
  awayXg    Float
  played    Boolean @default(false)

  // Detailed events: scorers/assists stored as JSON for transparency & profiles.
  // [{ playerRatingId, teamId, type: "GOAL"|"ASSIST", minute }]
  events Json @default("[]")

  createdAt DateTime @default(now())
}

model LeagueTableRow {
  id     String @id @default(cuid())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  teamId String @unique
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  played   Int @default(0)
  won      Int @default(0)
  drawn    Int @default(0)
  lost     Int @default(0)
  goalsFor Int @default(0)
  goalsAg  Int @default(0)
  points   Int @default(0)
  position Int @default(0)

  updatedAt DateTime @updatedAt

  @@index([gameId, points])
}

// =============================================================================
// 3. ADMIN / AUTH
// =============================================================================

// Simple shared-password gate is handled at the app level (env var), but we
// keep an audit row for imports so you can see what's been loaded.
model ImportLog {
  id        String   @id @default(cuid())
  kind      String // "clubs" | "players" | "managers"
  rows      Int
  filename  String?
  createdAt DateTime @default(now())
}
